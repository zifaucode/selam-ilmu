---
interface Props {
  title: string;
  summary: string;
  category: string;
  slug: string;
  tags?: string[];
  icon?: string;
}

const { title, summary, category, slug, tags = [], icon } = Astro.props;

const categoryRomans: Record<string, string> = {
  civilizations: 'I', spirituality: 'II', theology: 'III', cultures: 'IV',
  scriptures: 'V', philosophy: 'VI', figures: 'VII', books: 'VIII', glossary: 'IX',
};

const roman = categoryRomans[category] || 'X';
---

<a
  href={`/${category}/${slug}`}
  class="group block border-illuminated p-6 relative"
>
  <!-- Decorative Roman Numeral Background -->
  <div class="absolute -right-4 -bottom-4 font-display font-bold text-9xl text-midnight-surface select-none group-hover:text-abyss/50 transition-colors duration-500 z-0">
    {roman}
  </div>

  <div class="relative z-10 flex flex-col h-full">
    <!-- Category Badge -->
    <div class="flex items-center gap-2 mb-4">
      <span class="text-[10px] font-sans uppercase tracking-[0.2em] text-cyber-teal border border-cyber-teal/30 px-2 py-0.5 bg-cyber-teal/5">
        {category}
      </span>
    </div>

    <!-- Title -->
    <h3 class="font-display font-bold text-xl text-text-primary group-hover:text-gold-radiant transition-colors mb-3 leading-snug">
      {title}
    </h3>

    <!-- Summary -->
    <p class="font-serif text-sm text-text-secondary italic leading-relaxed line-clamp-3 mb-6 flex-grow">
      {summary}
    </p>

    <!-- Footer / Tags -->
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-midnight-border group-hover:border-gold-ancient/30 transition-colors">
      <div class="flex gap-2">
        {tags.slice(0, 2).map(tag => (
          <span class="text-[9px] font-sans uppercase tracking-wider text-text-tertiary">#{tag}</span>
        ))}
      </div>
      <div class="w-6 h-[1px] bg-gold-ancient/50 group-hover:w-10 group-hover:bg-cyber-teal transition-all duration-300"></div>
    </div>
  </div>
</a>
