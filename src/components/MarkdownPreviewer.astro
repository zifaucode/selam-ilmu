---
// src/components/MarkdownPreviewer.astro
---
<div class="previewer-container w-full max-w-7xl mx-auto p-4 sm:p-6">
  <div class="mb-8 text-center animate-fade-in">
    <h1 class="text-3xl md:text-4xl font-display font-bold text-gold-radiant mb-3">Live Markdown Preview</h1>
    <p class="text-text-secondary max-w-2xl mx-auto">Tulis atau tempel kode Markdown di sebelah kiri, dan lihat hasil visualnya secara langsung di sebelah kanan.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 min-h-[700px] animate-slide-up">
    
    <!-- Left Panel: Markdown Editor -->
    <div class="bg-midnight-raised border border-midnight-border rounded-xl flex flex-col shadow-2xl h-full max-h-[80vh]">
        <div class="bg-midnight-base border-b border-midnight-border py-4 px-5 flex justify-between items-center relative z-10">
            <h2 class="text-text-primary font-medium flex items-center gap-2">
                <svg class="w-5 h-5 text-gold-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                Kode Markdown
            </h2>
            <button id="btn-copy-md" class="text-xs px-3 py-1.5 bg-midnight-surface text-text-primary border border-midnight-border hover:border-gold-ancient/50 hover:text-gold-bright rounded transition-all flex items-center gap-1.5 cursor-pointer">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                Salin
            </button>
        </div>
        <div class="flex-1 p-0 overflow-hidden bg-midnight-surface relative rounded-b-xl">
            <textarea id="markdown-input" class="w-full h-full p-5 bg-transparent border-none resize-none outline-none text-text-secondary font-mono text-sm leading-relaxed" placeholder="Ketik markdown Anda di sini...&#10;&#10;# Judul Besar&#10;## Subjudul&#10;&#10;- Daftar 1&#10;- Daftar 2&#10;&#10;**Teks Tebal** dan *Teks Miring*"></textarea>
        </div>
    </div>

    <!-- Right Panel: Live Preview -->
    <div class="bg-midnight-raised border border-midnight-border rounded-xl flex flex-col shadow-2xl h-full max-h-[80vh]">
        <div class="bg-midnight-base border-b border-midnight-border py-4 px-5 flex items-center gap-2 relative z-10">
            <svg class="w-5 h-5 text-cyber-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <h2 class="text-text-primary font-medium">Pratinjau Visual</h2>
        </div>
        <div class="flex-1 p-6 md:p-8 bg-midnight-surface rounded-b-xl overflow-auto">
            <div id="live-preview" class="prose-article prose-invert max-w-none">
                <div class="text-text-tertiary italic text-sm text-center mt-20 flex flex-col items-center gap-3">
                    <svg class="w-10 h-10 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    Pratinjau akan muncul di sini...
                </div>
            </div>
        </div>
    </div>
    
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mdInput = document.getElementById('markdown-input');
    const preview = document.getElementById('live-preview');
    const btnCopy = document.getElementById('btn-copy-md');
    
    const placeholderHtml = `
        <div class="text-text-tertiary italic text-sm text-center mt-20 flex flex-col items-center gap-3">
            <svg class="w-10 h-10 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Pratinjau akan muncul di sini...
        </div>
    `;

    // Initialize with default template text if needed, or leave blank
    
    // Auto-resize textarea to fit content (optional, but since we use fixed panel with scrolling, it's better to just let it scroll)
    
    // Live update function
    function updatePreview() {
        const text = mdInput.value;
        if (!text || text.trim() === '') {
            preview.innerHTML = placeholderHtml;
        } else {
            preview.innerHTML = marked.parse(text);
        }
    }

    // Listeners
    if (mdInput && preview) {
        mdInput.addEventListener('input', updatePreview);
        // Trigger initial render if there's predefined text
        updatePreview();
    }

    // Sync scrolling (Optional Enhancement)
    if (mdInput && preview) {
        let isSyncingLeft = false;
        let isSyncingRight = false;

        const rightPanelScroll = preview.parentElement; // The div with overflow-auto

        mdInput.addEventListener('scroll', function(e) {
            if (!isSyncingLeft) {
                isSyncingRight = true;
                const percentage = this.scrollTop / (this.scrollHeight - this.clientHeight);
                rightPanelScroll.scrollTop = percentage * (rightPanelScroll.scrollHeight - rightPanelScroll.clientHeight);
            }
            isSyncingLeft = false;
        });

        rightPanelScroll.addEventListener('scroll', function(e) {
            if (!isSyncingRight) {
                isSyncingLeft = true;
                const percentage = this.scrollTop / (this.scrollHeight - this.clientHeight);
                mdInput.scrollTop = percentage * (mdInput.scrollHeight - mdInput.clientHeight);
            }
            isSyncingRight = false;
        });
    }

    // Copy Action
    if (btnCopy && mdInput) {
        btnCopy.addEventListener('click', () => {
            if (!mdInput.value) return;
            navigator.clipboard.writeText(mdInput.value).then(() => {
                const originalText = btnCopy.innerHTML;
                btnCopy.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Tersalin!`;
                setTimeout(() => btnCopy.innerHTML = originalText, 2000);
            });
        });
    }
  });
</script>
