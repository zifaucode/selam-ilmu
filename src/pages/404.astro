---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "404 - Halaman Tidak Ditemukan";
const description = "Halaman yang Anda cari mungkin telah lapuk dimakan usia atau hilang dari perpustakaan.";
---

<BaseLayout title={title} description={description}>
  <div class="min-h-[70vh] flex items-center justify-center px-4 sm:px-6 lg:px-8 animate-slide-up">
    <div class="max-w-xl w-full text-center space-y-8">
      
      <!-- Custom Logo Display -->
      <div class="flex justify-center mb-12 relative group">
        <div class="absolute inset-0 bg-gold-ancient/20 blur-xl rounded-full scale-110 group-hover:bg-cyber-teal/20 transition-colors duration-700"></div>
        <div class="w-32 h-32 md:w-40 md:h-40 relative z-10 rounded-2xl overflow-hidden border border-gold-ancient/50 shadow-[0_0_30px_rgba(245,215,110,0.15)] group-hover:border-cyber-teal/50 transition-colors duration-700">
          <img src="/logo.jpg" alt="Selam Ilmu" class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700" />
        </div>
      </div>

      <!-- Error Text -->
      <div>
        <h1 class="font-display font-black text-6xl md:text-8xl text-transparent bg-clip-text bg-gradient-to-b from-text-primary to-midnight-border tracking-tight mb-4">
          404
        </h1>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-gold-ancient uppercase tracking-widest mb-6">
          Naskah Hilang
        </h2>
        <p class="font-serif italic text-text-secondary text-lg leading-relaxed max-w-md mx-auto">
          "Halaman yang Anda cari mungkin telah lapuk dimakan usia, dipindahkan ke rak lain, atau memang belum pernah tertulis dalam catatan peradaban."
        </p>
      </div>

      <!-- Actions -->
      <div class="pt-8">
        <a href="/" class="inline-flex items-center gap-3 px-8 py-4 bg-transparent border border-cyber-teal/50 text-cyber-teal hover:bg-cyber-teal hover:text-abyss font-sans uppercase tracking-widest text-sm font-bold transition-all group relative overflow-hidden">
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Kembali ke Beranda
        </a>
      </div>

    </div>
  </div>
</BaseLayout>
